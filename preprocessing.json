2/manual.shtml","key":"SowQUO1LPD"},{"type":"text","value":" for FastQC analysis and read alignment.\nWhen using Trimmomatic, you can specify the minimum length of the sequence as a percentage of the input read with the ","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"hkoJT3OOio"},{"type":"inlineCode","value":"--trimmomatic-options='MINLEN:'","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"TYPYnfsUro"},{"type":"text","value":" parameter.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"uxPaKIZ7kv"}],"key":"AwmjgCM15w"},{"type":"code","lang":"bash","value":"# Downlodad host genome (ex.Human)\n$ conda activate kneaddata\n$ mkdir hostgenome\n$ kneaddata_database --download human_genome bowtie2 hostgenome/\n$ kneaddata --input1 input/seq1.fastq --input2 input/seq2.fastq --reference-db hostgenome/ --output kneaddataOutputPairedEnd --trimmomatic-options=\"MINLEN:90\"  \n$ conda deactivate","position":{"start":{"line":14,"column":1},"end":{"line":21,"column":1}},"key":"AGmPD2KC8L"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"▶Example of KneadData output","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"qRUnXhYp7l"}],"key":"lFyGIX2UXz"},{"type":"container","children":[{"type":"image","style":{"width":"90%"},"url":"/metainsight-book/build/d6bf94bea06c3622069df781188dd6bd.png","alt":"","data":{"altTextIsAutoGenerated":true},"key":"bxgfK7FjkD","urlSource":"https://github.com/sujin9819/MetaInsight/blob/main/SOP/MetaGenomic/img/G_5_2.png?raw=true","urlOptimized":"/metainsight-book/build/d6bf94bea06c3622069df781188dd6bd.webp"},{"type":"caption","children":[{"type":"paragraph","children":[{"type":"strong","children":[],"key":"j7qw3FoDow"}],"key":"TVnBsOYgJy"}],"key":"dRPO94xGY3"}],"enumerator":"2","key":"tN32UUbMO4"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"▶Example of Output files","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"W2W94MNZPn"}],"key":"HOFXISvBhh"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":29,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":29,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"seq.kneaddata_human_genome_bowtie2_contam.fastq\n: Contaminant reads aligned to the human genome","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"cClD3tK6nP"}],"key":"ASNbcktNdu"}],"key":"FQJsnOSzv1"},{"type":"listItem","spread":true,"position":{"start":{"line":31,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"seq.kneaddata.fastq\n: Reads not aligned to the human genome","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"q2HluAZo1w"}],"key":"xZwElbXcOC"}],"key":"OE2qQAn1Mb"},{"type":"listItem","spread":true,"position":{"start":{"line":33,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"seq.kneaddata.trimmed.fastq\n: trimmed reads","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"X3BGr1Izuh"}],"key":"swdfFyrPih"}],"key":"SnX3WuqbTR"},{"type":"listItem","spread":true,"position":{"start":{"line":35,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"seq.kneaddata.log\n: log file","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"ta487SfA9w"}],"key":"N8E5WjXB0L"}],"key":"FVlzFtgaUI"}],"key":"bMb9MWTdS3"},{"type":"heading","depth":2,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Long reads","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"asW5xeDUQk"}],"identifier":"long-reads","label":"Long reads","html_id":"long-reads","implicit":true,"key":"UL27PlJMd0"},{"type":"paragraph","position":{"start":{"line":41,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"The mapping methods typically employed for short reads are not well-suited for long reads.\nShort reads are commonly mapped using the seed-and-extend method, which extends based on single base matches.\nHowever, long reads require multiple consistent matches across the read for accurate alignment.\nWhen seed-and-extend methods are applied to long reads, issues with extension and alignment accuracy can arise.\nTo address these challenges, alternative methods like seed-and-chain have been developed.","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"d3NwCHcAd6"}],"key":"drS6UrEp09"},{"type":"paragraph","position":{"start":{"line":47,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"link","url":"https://github.com/lh3/minimap2","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"minimap2","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"wZNtsk1ITD"}],"urlSource":"https://github.com/lh3/minimap2","error":true,"key":"ZJWkWmHUmg"},{"type":"text","value":" is a versatile sequence mapping program that is effective for aligning and analyzing long reads such as PacBio and Oxford Nanopore technologies.\nIn this pipeline, we will use minimap2 for long read mapping.","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"CpTvAXa4Ae"}],"key":"JiLNRrNTqz"},{"type":"code","lang":"bash","value":"$ conda install -c bioconda minimap2\n$ conda activate minimap2\n# General usage of minimap2\n# minimap2 –ax map-hifi ref.fa query.fq > alignment.sam\n$ minimap2 -ax map-hifi GCF_000001405.40_GRCh38.p14_genomic.fna N_008_HiFi.fastq.gz > N008.aln.sam\n# Convert sam files to bam files\n$ samtools view -Sb N008.aln.sam > N008.aln.bam \n# remove host genome aligned read\n$ samtools view -bf 0x04 N008.aln.bam > N008.aln.unmapped.bam\n# convert bam files to fastq\n$ samtools bam2fq N008.aln.unmapped.bam > N008.aln.unmapped.fq","position":{"start":{"line":50,"column":1},"end":{"line":62,"column":1}},"key":"KUhFNXCz0n"}],"key":"cAw00ogFo6"}],"key":"yh2T1hqKWu"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Metagenomic analysis tools","url":"/installation","group":"Metagenomics"},"next":{"title":"De novo assembly","url":"/denovo-assembly","group":"Metagenomics"}}},"domain":"http://localhost:3002"}