hildren":[{"type":"paragraph","children":[{"type":"text","value":"Homogenize the sample by vortexing at 6.0 m/s for 40 seconds using a beadbeater, such as the FastPrep 24 instrument. If it appears that there was insufficient homogenization due to large debris, perform additional homogenization under the same conditions for all samples, but with careful intervals and attention to the heat generated by the vibration.","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"PZgJqzAgui"}],"key":"Zwp2w1ye1w"}],"key":"nrz9BeVCGs"},{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Centrifuge the sample at 14,000×g for 5 minutes and transfer the supernatant to a 2 ml tube.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"uO1ydUcYsS"}],"key":"V44M7lHJUZ"}],"key":"lTn1rlsl2G"},{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Add 250 μl of PPS solution. Invert slowly (do not vortex) and keep at 4°C for 10 minutes, then centrifuge at 14,000×g for 2 minutes.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"QdsLWfClI3"}],"key":"FVTg9EvyFr"}],"key":"ZAmIoIDwUG"},{"type":"listItem","spread":true,"position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Transfer 1 ml of the binding matrix solution to a 15 ml conical tube during centrifugation.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"nP0mBgDBAo"}],"key":"KrP2tcKPWf"}],"key":"w7jxS4xHaB"},{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Transfer the supernatant from the centrifuged sample to the 15 ml tube containing the binding matrix solution. Invert.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"gX0fZjK4Cn"}],"key":"ynqCrkQ2Kb"}],"key":"oKsTVsmbur"},{"type":"listItem","spread":true,"position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Place the tube in the shaking incubator at an angle that allows the sample to mix well and let it sit for 3-5 minutes.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"J6kI6iLIA3"}],"key":"xDdmDCzCTN"}],"key":"ZW65urOKvM"},{"type":"listItem","spread":true,"position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Centrifuge at 14,000×g for 2 minutes and discard the supernatant.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"KT8exjYNuo"}],"key":"mbNklSfdg6"}],"key":"Jl2HQAELE5"},{"type":"listItem","spread":true,"position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Add 1 ml of wash buffer #1 and gently resuspend the pellet.","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"GWvVV2nK9E"}],"key":"rXfQiGMn3o"}],"key":"p9Npjrg1Yn"},{"type":"listItem","spread":true,"position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Transfer 600 μl of the binding matrix and wash buffer #1 mixture to a SPIN filter tube. Centrifuge at 14,000×g for 1 minute, empty the catch tube, transfer the remaining solution, and centrifuge again. Empty the catch tube once more.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"ifWScBX0DB"}],"key":"uFGjSF3Puw"}],"key":"fDuyqIjDSE"},{"type":"listItem","spread":true,"position":{"sta